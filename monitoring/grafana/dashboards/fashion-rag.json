{
  "title": "Multimodal Fashion RAG",
  "uid": "fashion-rag",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "templating": {"list": []},
  "annotations": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency per stage (p50 / p95 / p99)",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (stage, le) (rate(search_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(search_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{stage}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (stage, le) (rate(search_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{stage}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (req/s) by endpoint",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(search_requests_total[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (5m)",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(search_requests_total{status=\"error\"}[5m])) / clamp_min(sum(rate(search_requests_total[5m])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "LLM errors by type",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (type) (rate(llm_errors_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "heatmap",
      "title": "Total latency heatmap",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (le) (rate(search_duration_seconds_bucket{stage=\"total\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ]
}
