# Скопируй этот файл в .env и подставь свои значения.
# .env гитигнорится — настоящие ключи туда кладём и не коммитим.

# ---------- LLM backend ----------
LLM_BACKEND=api

# Работает с любым OpenAI-совместимым API: Cerebras, Groq, OpenAI, OpenRouter, Ollama.
LLM_API_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=llama3.1-8b

# Альтернативы:
# LLM_API_BASE_URL=https://api.groq.com/openai/v1          # Groq
# LLM_API_BASE_URL=https://api.openai.com/v1               # OpenAI
# LLM_API_BASE_URL=https://openrouter.ai/api/v1            # OpenRouter
# LLM_API_BASE_URL=http://localhost:11434/v1               # Ollama (локально)

# Локальный GGUF через llama-cpp-python (вместо hosted API):
# LLM_BACKEND=local
# LOCAL_MODEL_PATH=/path/to/model.gguf

# ---------- Qdrant ----------
QDRANT_URL=http://localhost:6333

# ---------- Redis (shared cache для LLM-вызовов) ----------
# Оставь пустым / закомментируй, чтобы отключить кеш (fail-open).
REDIS_URL=redis://localhost:6379/0

# ---------- Search tuning ----------
RERANK_CANDIDATES=20
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
SPARSE_MODEL_NAME=Qdrant/bm42-all-minilm-l6-v2-attentions

# ---------- Evaluation ----------
EVAL_NUM_QUERIES=30
